generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  INVESTOR
  TECH_SUPPORT
  SALES_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  REVIEW
  ACTIVE
  FUNDED
  PAUSED
  CLOSED
}

enum InvestmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum DividendPeriodStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum DividendPaymentStatus {
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

enum ProjectSubmissionStatus {
  SUBMITTED
  REVIEW
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  INVESTMENT
  RETURN
  WITHDRAWAL
  ADJUSTMENT
}

enum SupportThreadStatus {
  OPEN
  PENDING
  CLOSED
}

enum SupportQueue {
  TECH_SUPPORT
  SALES
}

enum DocumentKind {
  PROJECT
  LEGAL
  COMPLIANCE
  REPORT
  CONTRACT
}

enum PayoutFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String?
  passwordHash           String?
  role                   Role                    @default(INVESTOR)
  emailVerified          DateTime?
  blockedAt              DateTime?
  blockedUntil           DateTime?
  blockReason            String?                 @db.Text
  blockedById            String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  investorProfile        InvestorProfile?
  kycApplications        KycApplication[]
  wallet                 Wallet?
  investments            InvestmentApplication[]
  projectSubmissions     ProjectSubmission[]
  paymentConfirmations   PaymentConfirmation[]   @relation("PaymentReviewer")
  auditLogs              AdminAuditLog[]
  twoFactorSetting       TwoFactorSetting?
  supportThreads         SupportThread[]         @relation("SupportThreadUser")
  assignedSupportThreads SupportThread[]         @relation("SupportThreadAssignee")
  assignedGuestSupportThreads GuestSupportThread[] @relation("GuestSupportThreadAssignee")
  supportMessages        SupportMessage[]        @relation("SupportMessageSender")
  notifications          Notification[]          @relation("NotificationRecipient")
  authoredNotifications  Notification[]          @relation("NotificationActor")
  dividendPayments       DividendPayment[]
  accounts               Account[]
  sessions               Session[]

  @@index([blockedAt])
  @@index([blockedUntil])
}

model InvestorProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  phone          String?
  phoneDialCode  String?
  country        String?
  city           String?
  dateOfBirth    DateTime?
  citizenship    String?
  address        String?
  riskAcceptedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycApplication {
  id            String    @id @default(cuid())
  userId        String
  status        KycStatus @default(DRAFT)
  sourceOfFunds String?
  occupation    String?
  documents     Json?
  reviewedAt    DateTime?
  reviewerNote  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                       String              @id @default(cuid())
  userId                   String              @unique
  trc20Address             String?             @unique
  trc20PrivateKeyEncrypted String?
  trc20AddressIssuedAt     DateTime?
  availableUsdt            Decimal             @default(0) @db.Decimal(18, 6)
  pendingUsdt              Decimal             @default(0) @db.Decimal(18, 6)
  reservedUsdt             Decimal             @default(0) @db.Decimal(18, 6)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions             WalletTransaction[]
}

model WalletTransaction {
  id                 String               @id @default(cuid())
  walletId           String
  type               TransactionType
  status             PaymentStatus        @default(PENDING)
  amountUsdt         Decimal              @db.Decimal(18, 6)
  txHash             String?              @unique
  destinationAddress String?
  note               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  wallet             Wallet               @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paymentReview      PaymentConfirmation?
  dividendPayment     DividendPayment?
}

model Project {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  titleRu             String
  titleEn             String
  summaryRu           String
  summaryEn           String
  descriptionRu       String
  descriptionEn       String
  expectedReturnRu    String?
  expectedReturnEn    String?
  expectedYieldRu     String?
  expectedYieldEn     String?
  stageRu             String?
  stageEn             String?
  currentProgressRu   String?                 @db.Text
  currentProgressEn   String?                 @db.Text
  fundraisingStartAt  DateTime?
  fundraisingEndAt    DateTime?
  plannedLaunchAt     DateTime?
  plannedDividendAt   DateTime?
  payoutFrequency     PayoutFrequency          @default(CUSTOM)
  participationTermRu String?
  participationTermEn String?
  raisePlanRu         String?                 @db.Text
  raisePlanEn         String?                 @db.Text
  status              ProjectStatus           @default(DRAFT)
  targetUsdt          Decimal                 @db.Decimal(18, 6)
  fundedUsdt          Decimal                 @default(0) @db.Decimal(18, 6)
  location            String?
  structure           String                  @default("Mudaraba")
  riskLevel           String?
  coverImage          String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  documents           ProjectDocument[]
  reports             ProjectReport[]
  investments         InvestmentApplication[]
  projectSubmissions  ProjectSubmission[]
  dividendPeriods     ProjectDividendPeriod[]
}

model ProjectDocument {
  id        String       @id @default(cuid())
  projectId String?
  titleRu   String
  titleEn   String
  kind      DocumentKind @default(PROJECT)
  fileUrl   String
  createdAt DateTime     @default(now())
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectReport {
  id          String    @id @default(cuid())
  projectId   String
  titleRu     String
  titleEn     String
  period      String
  fileUrl     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectSubmission {
  id                 String                  @id @default(cuid())
  userId             String
  title              String
  sector             String?
  location           String?
  targetUsdt         Decimal?                @db.Decimal(18, 6)
  projectId          String?
  structure          String?
  expectedReturn     String?
  expectedYield      String?
  stage              String?
  currentProgress    String?                 @db.Text
  fundraisingStartAt DateTime?
  fundraisingEndAt   DateTime?
  plannedLaunchAt    DateTime?
  plannedDividendAt  DateTime?
  payoutFrequency    PayoutFrequency          @default(CUSTOM)
  participationTerm  String?
  raisePlan          String?                 @db.Text
  summary            String                  @db.Text
  documents          Json?
  status             ProjectSubmissionStatus @default(SUBMITTED)
  adminNote          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  project            Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([userId])
}

model InvestmentApplication {
  id                 String           @id @default(cuid())
  userId             String
  projectId          String
  amountUsdt         Decimal          @db.Decimal(18, 6)
  reservedUsdt       Decimal          @default(0) @db.Decimal(18, 6)
  status             InvestmentStatus @default(PENDING)
  termsAcceptedAt    DateTime?
  contractAcceptedAt DateTime?
  adminNote          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dividendPayments   DividendPayment[]

  @@index([projectId])
  @@index([status])
  @@index([userId])
}

model ProjectDividendPeriod {
  id                  String               @id @default(cuid())
  projectId           String
  titleRu             String
  titleEn             String
  periodLabel         String
  periodStart         DateTime
  periodEnd           DateTime
  grossRevenueUsdt    Decimal              @default(0) @db.Decimal(18, 6)
  directCostUsdt      Decimal              @default(0) @db.Decimal(18, 6)
  operatingExpenseUsdt Decimal             @default(0) @db.Decimal(18, 6)
  netProfitUsdt       Decimal              @default(0) @db.Decimal(18, 6)
  investorPoolUsdt    Decimal              @default(0) @db.Decimal(18, 6)
  investorSharePercent Decimal             @default(0) @db.Decimal(9, 4)
  status              DividendPeriodStatus @default(DRAFT)
  adminNote           String?              @db.Text
  approvedAt          DateTime?
  paidAt              DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments            DividendPayment[]

  @@unique([projectId, periodLabel])
  @@index([periodStart, periodEnd])
  @@index([projectId, status])
}

model DividendPayment {
  id                  String                @id @default(cuid())
  periodId            String
  investmentId        String
  userId              String
  walletTransactionId String?               @unique
  amountUsdt          Decimal               @db.Decimal(18, 6)
  investmentAmountUsdt Decimal              @db.Decimal(18, 6)
  weight              Decimal               @default(0) @db.Decimal(18, 6)
  eligibleDays        Int                   @default(0)
  status              DividendPaymentStatus @default(CALCULATED)
  paidAt              DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  period              ProjectDividendPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  investment          InvestmentApplication @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction   WalletTransaction?    @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@unique([periodId, investmentId])
  @@index([investmentId])
  @@index([userId, status])
}

model PaymentConfirmation {
  id            String            @id @default(cuid())
  transactionId String            @unique
  reviewerId    String?
  status        PaymentStatus
  reviewedAt    DateTime?
  note          String?
  transaction   WalletTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer      User?             @relation("PaymentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
}

model SupportThread {
  id                    String              @id @default(cuid())
  userId                String
  assignedToId          String?
  status                SupportThreadStatus @default(OPEN)
  queue                 SupportQueue        @default(TECH_SUPPORT)
  subject               String?
  lastCustomerMessageAt DateTime?
  lastManagerMessageAt  DateTime?
  closedAt              DateTime?
  rating                Int?
  ratingComment         String?
  ratedAt               DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  user                  User                @relation("SupportThreadUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo            User?               @relation("SupportThreadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages              SupportMessage[]

  @@index([assignedToId])
  @@index([queue])
  @@index([rating])
  @@index([status])
  @@index([userId])
}

model SupportMessage {
  id        String        @id @default(cuid())
  threadId  String
  senderId  String?
  body      String        @db.Text
  internal  Boolean       @default(false)
  createdAt DateTime      @default(now())
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User?         @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([threadId])
}

model GuestSupportThread {
  id                    String              @id @default(cuid())
  publicToken           String              @unique
  name                  String
  email                 String
  contact               String?
  subject               String?
  status                SupportThreadStatus @default(OPEN)
  queue                 SupportQueue        @default(TECH_SUPPORT)
  assignedToId          String?
  lastGuestMessageAt    DateTime?
  lastManagerMessageAt  DateTime?
  closedAt              DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  assignedTo            User?               @relation("GuestSupportThreadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages              GuestSupportMessage[]

  @@index([assignedToId])
  @@index([email])
  @@index([queue])
  @@index([status])
}

model GuestSupportMessage {
  id         String             @id @default(cuid())
  threadId    String
  senderKind  String
  senderName  String?
  body        String             @db.Text
  createdAt   DateTime           @default(now())
  thread      GuestSupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([threadId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  actorId   String?
  titleRu   String
  titleEn   String
  bodyRu    String    @db.Text
  bodyEn    String    @db.Text
  type      String    @default("system")
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([readAt])
  @@index([type])
  @@index([userId, readAt, createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model SiteContent {
  key           String   @id
  homeContent   Json?
  footerContent Json?
  legalContent  Json?
  faqContent    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TwoFactorSetting {
  id         String   @id @default(cuid())
  userId     String   @unique
  enabled    Boolean  @default(false)
  secretHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
