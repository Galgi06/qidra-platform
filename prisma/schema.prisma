generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  INVESTOR
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  REVIEW
  ACTIVE
  FUNDED
  PAUSED
  CLOSED
}

enum InvestmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  INVESTMENT
  RETURN
  WITHDRAWAL
  ADJUSTMENT
}

enum DocumentKind {
  PROJECT
  LEGAL
  COMPLIANCE
  REPORT
  CONTRACT
}

model User {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  name                 String?
  passwordHash         String?
  role                 Role                    @default(INVESTOR)
  emailVerified        DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  investorProfile      InvestorProfile?
  kycApplications      KycApplication[]
  wallet               Wallet?
  investments          InvestmentApplication[]
  paymentConfirmations PaymentConfirmation[]   @relation("PaymentReviewer")
  auditLogs            AdminAuditLog[]
  twoFactorSetting     TwoFactorSetting?
  accounts             Account[]
  sessions             Session[]
}

model InvestorProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  phone          String?
  country        String?
  city           String?
  dateOfBirth    DateTime?
  citizenship    String?
  address        String?
  riskAcceptedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycApplication {
  id            String    @id @default(cuid())
  userId        String
  status        KycStatus @default(DRAFT)
  sourceOfFunds String?
  occupation    String?
  documents     Json?
  reviewedAt    DateTime?
  reviewerNote  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                       String              @id @default(cuid())
  userId                   String              @unique
  trc20Address             String?             @unique
  trc20PrivateKeyEncrypted String?
  trc20AddressIssuedAt     DateTime?
  availableUsdt            Decimal             @default(0) @db.Decimal(18, 6)
  pendingUsdt              Decimal             @default(0) @db.Decimal(18, 6)
  reservedUsdt             Decimal             @default(0) @db.Decimal(18, 6)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions             WalletTransaction[]
}

model WalletTransaction {
  id                 String               @id @default(cuid())
  walletId           String
  type               TransactionType
  status             PaymentStatus        @default(PENDING)
  amountUsdt         Decimal              @db.Decimal(18, 6)
  txHash             String?
  destinationAddress String?
  note               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  wallet             Wallet               @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paymentReview      PaymentConfirmation?
}

model Project {
  id            String                  @id @default(cuid())
  slug          String                  @unique
  titleRu       String
  titleEn       String
  summaryRu     String
  summaryEn     String
  descriptionRu String
  descriptionEn String
  status        ProjectStatus           @default(DRAFT)
  targetUsdt    Decimal                 @db.Decimal(18, 6)
  fundedUsdt    Decimal                 @default(0) @db.Decimal(18, 6)
  location      String?
  structure     String                  @default("Mudaraba")
  riskLevel     String?
  coverImage    String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  documents     ProjectDocument[]
  reports       ProjectReport[]
  investments   InvestmentApplication[]
}

model ProjectDocument {
  id        String       @id @default(cuid())
  projectId String?
  titleRu   String
  titleEn   String
  kind      DocumentKind @default(PROJECT)
  fileUrl   String
  createdAt DateTime     @default(now())
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectReport {
  id          String    @id @default(cuid())
  projectId   String
  titleRu     String
  titleEn     String
  period      String
  fileUrl     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model InvestmentApplication {
  id                 String           @id @default(cuid())
  userId             String
  projectId          String
  amountUsdt         Decimal          @db.Decimal(18, 6)
  reservedUsdt       Decimal          @default(0) @db.Decimal(18, 6)
  status             InvestmentStatus @default(PENDING)
  termsAcceptedAt    DateTime?
  contractAcceptedAt DateTime?
  adminNote          String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PaymentConfirmation {
  id            String            @id @default(cuid())
  transactionId String            @unique
  reviewerId    String?
  status        PaymentStatus
  reviewedAt    DateTime?
  note          String?
  transaction   WalletTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer      User?             @relation("PaymentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model TwoFactorSetting {
  id         String   @id @default(cuid())
  userId     String   @unique
  enabled    Boolean  @default(false)
  secretHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
